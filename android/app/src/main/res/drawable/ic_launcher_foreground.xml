<!-- Adaptive-icon foreground: the Cairn stones (charcoal on the parchment
     background layer). Four stacked river-stone ellipses, drawn as arc paths
     since Android vector drawables have no <ellipse>. The whole cairn is
     scaled 0.86 about the canvas centre so it sits inside the 66dp adaptive
     safe zone (the base stone would otherwise poke past the mask on a round
     launcher). Colours come from design/Cairn App Icon.dc.html. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.86"
        android:scaleY="0.86">
        <path
            android:fillColor="#33302B"
            android:pathData="M29,79 a25,11.5 0 1,0 50,0 a25,11.5 0 1,0 -50,0 Z" />
        <path
            android:fillColor="#33302B"
            android:pathData="M37,61.5 a19.5,10 0 1,0 39,0 a19.5,10 0 1,0 -39,0 Z" />
        <path
            android:fillColor="#33302B"
            android:pathData="M37,46 a14.5,8.5 0 1,0 29,0 a14.5,8.5 0 1,0 -29,0 Z" />
        <path
            android:fillColor="#33302B"
            android:pathData="M45.5,32.5 a9.5,7.2 0 1,0 19,0 a9.5,7.2 0 1,0 -19,0 Z" />
    </group>
</vector>
