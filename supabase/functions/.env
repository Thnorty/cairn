# verify-proof Edge Function - tunable rate-limit config (NON-SENSITIVE).
#
# These are just numeric knobs and are safe to commit. The Edge Function reads
# them via Deno.env.get with these same values as built-in defaults, so the
# deployed function already behaves exactly as below even if these are never
# pushed to the secret store.
#
# To change a limit on the DEPLOYED function: edit the value here, then run
#   supabase secrets set --env-file supabase/functions/.env
# It takes effect on the next invocation; no code redeploy is needed.
#
# NEVER put real secrets in this file (GEMINI_API_KEY, service-role keys, the
# anon key, etc.). Those live ONLY in the Supabase secret vault, set with
# `supabase secrets set KEY=value`, and must never be committed.

# Max verify-proof calls per user per UTC day (durable, table-backed quota).
VERIFY_USER_DAILY_CAP=30

# Max verify-proof calls across ALL users per UTC day (global Gemini-cost ceiling).
VERIFY_GLOBAL_DAILY_CAP=10000

# In-memory per-instance burst limit (calls per 60s per user), first-line defense.
VERIFY_BURST_PER_MIN=20
