  "settingsHintEmphasis": "Settings › Apps › Cairn › Permissions",
  "@settingsHintEmphasis": {
    "description": "Bold middle clause of the Camera Unavailable screen's Settings hint banner, between settingsHintLead and settingsHintTrail, matching the design's own <strong> span in the middle of the sentence. This is the Android system Settings path to this app's permissions screen (Settings > Apps > Cairn > Permissions), where camera access is actually granted."
  },
  "settingsHintTrail": ". Gallery proofs still need a recent, in-the-moment photo.",
  "@settingsHintTrail": {
    "description": "Plain trailing clause of the Camera Unavailable screen's Settings hint banner, immediately following settingsHintEmphasis. The leading period is deliberate: it closes the sentence right after the bold span, matching the design's own punctuation placement."
